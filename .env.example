# Copy to .env and adjust as needed. docker-compose reads these for all three services.

DB_NAME=tdf_poule
DB_USER=tdf_poule
DB_PASSWORD=tdf_poule
DB_PORT=5432

BACKEND_PORT=8080
FRONTEND_PORT=8081

# Optional: unlocks the hidden /site-admin page (list + delete ANY poule, bypassing each
# poule's own organizer passphrase). Leave unset to disable that page entirely. If you set
# it, pick something long and random -- this is more powerful than any single poule's password.
SITE_ADMIN_SECRET=

# How many hours before stage 1's real confirmed start (2026-07-04 17:05 CEST, see
# backend/src/main/resources/schedule/tour_de_france_2026_schedule.json) swaps are free and
# uncapped. Defaults to 24 if unset.
FREE_SWAP_WINDOW_HOURS=24
